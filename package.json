{
  "name": "favorite-places",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "build:data": "uv run python3 scripts/build_data.py",
    "sync:sources": "uv run python3 scripts/build_data.py --refresh",
    "sync:sources:force": "uv run python3 scripts/build_data.py --refresh --refresh-force",
    "sync:source": "sh -c 'selector=\"$1\"; if [ \"$selector\" = \"--\" ]; then selector=\"$2\"; fi; uv run python3 scripts/build_data.py --refresh-list \"$selector\"' --",
    "refresh:data": "pnpm run sync:sources",
    "refresh:data:force": "pnpm run sync:sources:force",
    "refresh:data:list": "pnpm run sync:source --",
    "enrich:data": "uv run python3 scripts/build_data.py --enrich",
    "refresh:enrichment": "uv run python3 scripts/build_data.py --refresh-enrichment"
  },
  "dependencies": {
    "astro": "^6.1.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "typescript": "^5.9.3"
  }
}
