---
import GuideCard from "../components/GuideCard.astro";
import Layout from "../components/Layout.astro";
import { siteConfig } from "../data/site";
import { getGuideManifests } from "../lib/data";

const guides = getGuideManifests();
const guidesByCountry = Object.entries(
  guides.reduce<Record<string, typeof guides>>((accumulator, guide) => {
    const key = guide.country_name || "Unknown";
    accumulator[key] ??= [];
    accumulator[key].push(guide);
    return accumulator;
  }, {}),
).sort(([left], [right]) => left.localeCompare(right));
---

<Layout
  title={siteConfig.siteName}
  description={siteConfig.siteDescription}
>
  <section class="hero">
    <div class="hero-grid">
      <div class="section-stack">
        <p class="eyebrow">{siteConfig.home.eyebrow}</p>
        <h1>{siteConfig.home.title}</h1>
        <p class="lede">{siteConfig.home.intro}</p>
        <div class="hero-meta">
          <span class="stat-pill">{guides.length} guides</span>
          <span class="stat-pill">
            {guides.reduce((count, guide) => count + guide.place_count, 0)} places
          </span>
        </div>
      </div>

      <div class="section-stack">
        <p class="eyebrow">{siteConfig.home.highlightsHeading}</p>
        {siteConfig.home.highlights.map((highlight) => (
          <p class="small-copy">{highlight}</p>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Guides</p>
        <h2 class="section-title">Browse by country</h2>
      </div>
      <p class="small-copy">
        More travel notes at <a href={siteConfig.demFlyersUrl}>DEM Flyers</a>.
      </p>
    </div>

    {guidesByCountry.map(([countryName, countryGuides]) => (
      <div class="country-block">
        <div class="section-head">
          <div>
            <p class="eyebrow">{countryGuides.length} guide{countryGuides.length === 1 ? "" : "s"}</p>
            <h3 class="section-title">{countryName}</h3>
          </div>
        </div>

        <div class="card-grid">
          {countryGuides.map((guide) => (
            <GuideCard guide={guide} />
          ))}
        </div>
      </div>
    ))}
  </section>
</Layout>
