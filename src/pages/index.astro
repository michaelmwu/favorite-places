---

import GuideCard from "../components/GuideCard.astro";
import HomeGuideMap from "../components/HomeGuideMap.astro";
import Layout from "../components/Layout.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { siteConfig } from "../data/site";
import { getGuideManifests } from "../lib/data";
import { getHomeAsideHtml, getTemplateHtml } from "../lib/heroAsideContent";
import { renderRichText } from "../lib/renderRichText";

const guides = getGuideManifests();
const countryEntries = Object.entries(
  guides.reduce<Record<string, typeof guides>>((accumulator, guide) => {
    const key = guide.country_name || "Unknown";
    accumulator[key] ??= [];
    accumulator[key].push(guide);
    return accumulator;
  }, {}),
).sort(([left], [right]) => left.localeCompare(right));
const flagPattern = /[\u{1F1E6}-\u{1F1FF}]{2}/gu;
const getCountryFlag = (countryGuides: typeof guides) => {
  const flagCounts = countryGuides.reduce<Record<string, number>>((accumulator, guide) => {
    const flags = [...guide.title.matchAll(flagPattern)].map(([flag]) => flag);
    const flag = flags.at(-1);

    if (flag) {
      accumulator[flag] = (accumulator[flag] ?? 0) + 1;
    }

    return accumulator;
  }, {});

  return Object.entries(flagCounts).sort(([, leftCount], [, rightCount]) => rightCount - leftCount)[0]?.[0] ?? "";
};
const guidesByCountry = countryEntries.map(([countryName, countryGuides]) => ({
  countryGuides,
  countryName,
  countryFlag: getCountryFlag(countryGuides),
}));
const cityMarkerEmoji: Record<string, string> = {
  amsterdam: "🚲",
  bangkok: "🛺",
  barcelona: "🏖️",
  belfast: "🛳️",
  berlin: "🪩",
  "cape-town": "⛰️",
  chicago: "🌆",
  copenhagen: "🚲",
  dubai: "🏙️",
  florence: "🎨",
  fukuoka: "🍜",
  hakodate: "🌃",
  hanoi: "🛵",
  "hong-kong": "🌃",
  ibiza: "🎧",
  ishigaki: "🌺",
  kanazawa: "🍵",
  karuizawa: "🌲",
  kyoto: "⛩️",
  "las-vegas": "🎰",
  london: "🎡",
  "los-angeles": "🎬",
  madrid: "💃",
  melbourne: "☕",
  "mexico-city": "🌮",
  monaco: "🏎️",
  nagasaki: "⛪",
  nagoya: "🏯",
  "new-york": "🗽",
  oahu: "🏄",
  oaxaca: "🌮",
  paris: "🥐",
  sapporo: "🍺",
  "san-francisco": "🌉",
  seoul: "🎧",
  singapore: "🦁",
  sydney: "🎭",
  taipei: "🥟",
  takayama: "🏯",
  tokyo: "🗼",
  venice: "🛶",
  vienna: "🎼",
  yufuin: "♨️",
  zurich: "🏔️",
};
const normalizeCityMarkerKey = (cityName: string) =>
  cityName
    .toLowerCase()
    .replace(/&/g, " and ")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
const countryCodeToFlag = (countryCode: string | null) =>
  countryCode
    ? countryCode
        .toUpperCase()
        .replace(/./g, (character) => String.fromCodePoint(127397 + character.charCodeAt(0)))
    : "";
const cityInitials = (cityName: string) =>
  cityName
    .split(/[\s-]+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? "")
    .join("") || cityName.slice(0, 2).toUpperCase();
const guideMarkerLabel = (guide: (typeof guides)[number]) => {
  const titleFlags = [...guide.title.matchAll(flagPattern)].map(([flag]) => flag);
  const cityEmoji = cityMarkerEmoji[normalizeCityMarkerKey(guide.city_name)];
  return cityEmoji || titleFlags.at(-1) || countryCodeToFlag(guide.country_code) || cityInitials(guide.city_name);
};
const locationGuideCandidates = guides
  .filter((guide) => typeof guide.center_lat === "number" && typeof guide.center_lng === "number")
  .map((guide) => {
    const countryName = guide.country_name || "Unknown";

    return {
      cityName: guide.city_name || "",
      countryCode: guide.country_code,
      slug: guide.slug,
      title: guide.title,
      country: countryName.toLowerCase(),
      countryName,
      lat: guide.center_lat as number,
      lng: guide.center_lng as number,
      markerLabel: guideMarkerLabel(guide),
      placeCount: guide.place_count,
      url: `/guides/${guide.slug}/`,
    };
  });
const countryCount = guidesByCountry.length;
const placeCount = guides.reduce((count, guide) => count + guide.place_count, 0);
const homeAsideHtml = getHomeAsideHtml();
const homeHighlights = siteConfig.home.highlights
  .map((highlight) => renderRichText(highlight))
  .filter((highlight): highlight is string => Boolean(highlight));
const homeBeforeGuidesHtml = getTemplateHtml("home-before-guides.html");
const homeAfterGuidesHtml = getTemplateHtml("home-after-guides.html");
---

<Layout
  title={siteConfig.siteName}
  description={siteConfig.siteDescription}
>
  {siteConfig.home.showHero && (
    <section class="hero ui-hero">
      <div class="hero-grid ui-hero-grid">
        <div class="section-stack ui-stack">
          <p class="eyebrow ui-eyebrow">{siteConfig.home.eyebrow}</p>
          <h1 class="ui-display">{siteConfig.home.title}</h1>
          <p class="lede ui-lede">{siteConfig.home.intro}</p>
          {siteConfig.home.showHeroStats && (
            <div class="hero-meta ui-meta-row">
              <span class="stat-pill ui-pill">{guides.length} guides</span>
              <span class="stat-pill ui-pill">{countryCount} countries</span>
              <span class="stat-pill ui-pill">{placeCount} places</span>
            </div>
          )}
        </div>

        <div class="section-stack ui-stack">
          {homeAsideHtml ? (
            <div class="small-copy ui-copy ui-copy--sm rich-copy" set:html={homeAsideHtml} />
          ) : (
            <>
              <p class="eyebrow ui-eyebrow">{siteConfig.home.highlightsHeading}</p>
              {homeHighlights.map((highlight) => (
                <p class="small-copy ui-copy ui-copy--sm rich-copy" set:html={highlight} />
              ))}
            </>
          )}
        </div>
      </div>
    </section>
  )}

  {homeBeforeGuidesHtml && <div class="template-block rich-copy" set:html={homeBeforeGuidesHtml} />}

  {siteConfig.home.showGuideBrowser && (
    <section
      class="section ui-section"
      data-home-browser-root
      data-country-sections-visible={siteConfig.home.showCountrySections ? "true" : "false"}
    >
    <SectionHeading eyebrow={siteConfig.home.guidesEyebrow} title={siteConfig.home.guidesHeading}>
      {
        siteConfig.home.guidesLinkText && siteConfig.navLinks[1] && (
          <p slot="aside" class="small-copy ui-copy ui-copy--sm">
            <a href={siteConfig.navLinks[1].href}>{siteConfig.home.guidesLinkText}</a>
          </p>
        )
      }
    </SectionHeading>

    {siteConfig.home.showGuideBrowserControls && (
      <div class="controls-panel ui-control-panel country-browser" data-home-browser-controls>
      <div class="controls-grid">
        <div class="control-group">
          <label class="control-label ui-control-label" for="country-search">{siteConfig.home.searchLabel}</label>
          <input
            class="ui-input"
            id="country-search"
            name="country-search"
            type="search"
            placeholder={siteConfig.home.searchPlaceholder}
            data-home-search-input
          />
        </div>

        <div class="control-group">
          <span class="control-label ui-control-label">{siteConfig.home.showingLabel}</span>
          <p class="browse-count ui-copy" data-home-results-count>
            {guides.length} guides across {countryCount} countries
          </p>
        </div>

        {siteConfig.home.showMap && (
          <div class="control-group location-control-group">
            <span class="control-label ui-control-label">{siteConfig.home.nearMeLabel}</span>
            <div class="location-control-row">
              <button
                class="location-target-button"
                type="button"
                data-location-target
                aria-label="Show nearby guides"
                title="Show nearby guides"
              >
                <svg aria-hidden="true" viewBox="0 0 24 24" width="20" height="20">
                  <circle cx="12" cy="12" r="6.5" fill="none" stroke="currentColor" stroke-width="2"></circle>
                  <circle cx="12" cy="12" r="2" fill="currentColor"></circle>
                  <path
                    d="M12 2v3M12 19v3M2 12h3M19 12h3"
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-width="2"
                  ></path>
                </svg>
              </button>
              <p class="location-status ui-copy ui-copy--sm" data-location-status role="status" aria-live="polite"></p>
            </div>
          </div>
        )}

        <div class="control-group country-filter-group">
          <span class="control-label ui-control-label">{siteConfig.home.countriesLabel}</span>
          <div class="country-filter-list" data-country-filter-list>
            <button
              class="country-filter ui-tag-pill"
              type="button"
              data-country-filter
              data-country=""
              aria-pressed="true"
            >
              <span>{siteConfig.home.allCountriesLabel}</span>
              <span class="country-filter-count">{guides.length}</span>
            </button>
            {guidesByCountry.map(({ countryName, countryGuides, countryFlag }) => (
              <button
                class="country-filter ui-tag-pill"
                type="button"
                data-country-filter
                data-country={countryName.toLowerCase()}
                aria-pressed="false"
              >
                <span>{countryFlag ? `${countryName} ${countryFlag}` : countryName}</span>
                <span class="country-filter-count">{countryGuides.length}</span>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
    )}

    <div class="empty-state ui-empty-state" data-home-empty-state>
      {siteConfig.home.emptyStateText}
    </div>

    <div
      class="global-search-results ui-search-results"
      data-global-search-results
      role="status"
      aria-live="polite"
      aria-atomic="true"
      aria-hidden="true"
      hidden
    >
      <div class="ui-section-head">
        <div class="ui-section-heading">
          <p class="ui-eyebrow">{siteConfig.home.searchResultsEyebrow}</p>
          <h3 class="ui-section-title" data-global-search-title>{siteConfig.home.searchResultsHeading}</h3>
        </div>
      </div>
      <div class="search-results-toolbar" data-global-search-toolbar>
        <p class="small-copy ui-copy ui-copy--sm" data-global-search-summary></p>
        <fieldset class="search-view-toggle-group">
          <legend class="visually-hidden">Search results view</legend>
          <button
            class="search-view-toggle"
            type="button"
            data-search-view-toggle
            data-search-view="grouped"
            aria-pressed="true"
          >
            {siteConfig.home.searchResultsGroupedLabel}
          </button>
          <button
            class="search-view-toggle"
            type="button"
            data-search-view-toggle
            data-search-view="individual"
            aria-pressed="false"
          >
            {siteConfig.home.searchResultsIndividualLabel}
          </button>
        </fieldset>
      </div>
      <div class="search-country-grid" data-grouped-search-list></div>
      <div class="search-result-grid" data-global-search-list hidden></div>
      <div class="empty-state ui-empty-state" data-global-search-empty role="status" aria-live="polite">
        {siteConfig.home.searchResultsEmptyText}
      </div>
    </div>

    {siteConfig.home.showMap && <HomeGuideMap guides={locationGuideCandidates} />}

    {guidesByCountry.map(({ countryName, countryGuides, countryFlag }) => (
      <div class="country-block ui-country-block" data-country-block data-country={countryName.toLowerCase()}>
        <SectionHeading
          eyebrow={`${countryGuides.length} guide${countryGuides.length === 1 ? "" : "s"}`}
          title={countryFlag ? `${countryName} ${countryFlag}` : countryName}
          level={3}
        />

        <div class="card-grid ui-card-grid">
          {countryGuides.map((guide) => (
            <GuideCard guide={guide} />
          ))}
        </div>
      </div>
    ))}
  </section>
  )}

  {homeAfterGuidesHtml && <div class="template-block rich-copy" set:html={homeAfterGuidesHtml} />}

  {siteConfig.home.showGuideBrowser && <script is:inline type="module" src="/scripts/home-browser.js"></script>}
  {siteConfig.home.showGuideBrowser && <script is:inline type="module" src="/scripts/scroll-jump.js"></script>}
</Layout>
