---
import GuideCard from "../components/GuideCard.astro";
import Layout from "../components/Layout.astro";
import { getGuideManifests } from "../lib/data";

const guides = getGuideManifests();
const guidesByCountry = Object.entries(
  guides.reduce<Record<string, typeof guides>>((accumulator, guide) => {
    const key = guide.country_name || "Unknown";
    accumulator[key] ??= [];
    accumulator[key].push(guide);
    return accumulator;
  }, {}),
).sort(([left], [right]) => left.localeCompare(right));
---

<Layout
  title="Favorite Places"
  description="A personal collection of saved-place guides built for sharing, searching, and quick Google Maps handoff."
>
  <section class="hero">
    <div class="hero-grid">
      <div class="section-stack">
        <p class="eyebrow">Favorite Places</p>
        <h1>Saved places, but actually readable.</h1>
        <p class="lede">
          These guides start from public Google Maps saved lists, then add curation, tags, top picks,
          and much faster scanning on mobile. The actual save and navigation flow still belongs to
          Google Maps. The presentation layer does not.
        </p>
        <div class="hero-meta">
          <span class="stat-pill">{guides.length} guides</span>
          <span class="stat-pill">
            {guides.reduce((count, guide) => count + guide.place_count, 0)} places
          </span>
          <span class="stat-pill">Static-first</span>
        </div>
      </div>

      <div class="section-stack">
        <p class="eyebrow">What makes this better</p>
        <p class="small-copy">Top picks surface first instead of disappearing inside a giant list.</p>
        <p class="small-copy">List tags and country grouping make the site browseable before search.</p>
        <p class="small-copy">Every place card hands off directly into Google Maps in one tap.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Guides</p>
        <h2 class="section-title">Browse by country</h2>
      </div>
      <p class="small-copy">Static builds, manual taste, fast handoff.</p>
    </div>

    {guidesByCountry.map(([countryName, countryGuides]) => (
      <div class="country-block">
        <div class="section-head">
          <div>
            <p class="eyebrow">{countryGuides.length} guide{countryGuides.length === 1 ? "" : "s"}</p>
            <h3 class="section-title">{countryName}</h3>
          </div>
        </div>

        <div class="card-grid">
          {countryGuides.map((guide) => (
            <GuideCard guide={guide} />
          ))}
        </div>
      </div>
    ))}
  </section>
</Layout>
