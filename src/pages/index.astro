---
import GuideCard from "../components/GuideCard.astro";
import HomeGuideMap from "../components/HomeGuideMap.astro";
import Layout from "../components/Layout.astro";
import { siteConfig } from "../data/site";
import { getGuideManifests } from "../lib/data";

const guides = getGuideManifests();
const countryEntries = Object.entries(
  guides.reduce<Record<string, typeof guides>>((accumulator, guide) => {
    const key = guide.country_name || "Unknown";
    accumulator[key] ??= [];
    accumulator[key].push(guide);
    return accumulator;
  }, {}),
).sort(([left], [right]) => left.localeCompare(right));
const flagPattern = /[\u{1F1E6}-\u{1F1FF}]{2}/gu;
const getCountryFlag = (countryGuides: typeof guides) => {
  const flagCounts = countryGuides.reduce<Record<string, number>>((accumulator, guide) => {
    const flags = [...guide.title.matchAll(flagPattern)].map(([flag]) => flag);
    const flag = flags.at(-1);

    if (flag) {
      accumulator[flag] = (accumulator[flag] ?? 0) + 1;
    }

    return accumulator;
  }, {});

  return Object.entries(flagCounts).sort(([, leftCount], [, rightCount]) => rightCount - leftCount)[0]?.[0] ?? "";
};
const guidesByCountry = countryEntries.map(([countryName, countryGuides]) => ({
  countryGuides,
  countryName,
  countryFlag: getCountryFlag(countryGuides),
}));
const cityMarkerEmoji: Record<string, string> = {
  amsterdam: "🚲",
  bangkok: "🛺",
  barcelona: "🏖️",
  belfast: "🛳️",
  berlin: "🪩",
  "cape-town": "⛰️",
  chicago: "🌆",
  copenhagen: "🚲",
  dubai: "🏙️",
  florence: "🎨",
  fukuoka: "🍜",
  hakodate: "🌃",
  hanoi: "🛵",
  "hong-kong": "🌃",
  ibiza: "🎧",
  ishigaki: "🌺",
  kanazawa: "🍵",
  karuizawa: "🌲",
  kyoto: "⛩️",
  "las-vegas": "🎰",
  london: "🎡",
  "los-angeles": "🎬",
  madrid: "💃",
  melbourne: "☕",
  "mexico-city": "🌮",
  monaco: "🏎️",
  nagasaki: "⛪",
  nagoya: "🏯",
  "new-york": "🗽",
  oahu: "🏄",
  oaxaca: "🌮",
  paris: "🥐",
  sapporo: "🍺",
  "san-francisco": "🌉",
  seoul: "🎧",
  singapore: "🦁",
  sydney: "🎭",
  taipei: "🥟",
  takayama: "🏯",
  tokyo: "🗼",
  venice: "🛶",
  vienna: "🎼",
  yufuin: "♨️",
  zurich: "🏔️",
};
const normalizeCityMarkerKey = (cityName: string) =>
  cityName
    .toLowerCase()
    .replace(/&/g, " and ")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
const countryCodeToFlag = (countryCode: string | null) =>
  countryCode
    ? countryCode
        .toUpperCase()
        .replace(/./g, (character) => String.fromCodePoint(127397 + character.charCodeAt(0)))
    : "";
const cityInitials = (cityName: string) =>
  cityName
    .split(/[\s-]+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? "")
    .join("") || cityName.slice(0, 2).toUpperCase();
const guideMarkerLabel = (guide: (typeof guides)[number]) => {
  const titleFlags = [...guide.title.matchAll(flagPattern)].map(([flag]) => flag);
  const cityEmoji = cityMarkerEmoji[normalizeCityMarkerKey(guide.city_name)];
  return cityEmoji || titleFlags.at(-1) || countryCodeToFlag(guide.country_code) || cityInitials(guide.city_name);
};
const locationGuideCandidates = guides
  .filter((guide) => typeof guide.center_lat === "number" && typeof guide.center_lng === "number")
  .map((guide) => {
    const countryName = guide.country_name || "Unknown";

    return {
      cityName: guide.city_name || "",
      countryCode: guide.country_code,
      slug: guide.slug,
      title: guide.title,
      country: countryName.toLowerCase(),
      countryName,
      lat: guide.center_lat as number,
      lng: guide.center_lng as number,
      markerLabel: guideMarkerLabel(guide),
      placeCount: guide.place_count,
      url: `/guides/${guide.slug}/`,
    };
  });
const countryCount = guidesByCountry.length;
const placeCount = guides.reduce((count, guide) => count + guide.place_count, 0);
---

<Layout
  title={siteConfig.siteName}
  description={siteConfig.siteDescription}
>
  <section class="hero">
    <div class="hero-grid">
      <div class="section-stack">
        <p class="eyebrow">{siteConfig.home.eyebrow}</p>
        <h1>{siteConfig.home.title}</h1>
        <p class="lede">{siteConfig.home.intro}</p>
        <div class="hero-meta">
          <span class="stat-pill">{guides.length} guides</span>
          <span class="stat-pill">{countryCount} countries</span>
          <span class="stat-pill">{placeCount} places</span>
        </div>
      </div>

      <div class="section-stack">
        <p class="eyebrow">{siteConfig.home.highlightsHeading}</p>
        {siteConfig.home.highlights.map((highlight) => (
          <p class="small-copy">{highlight}</p>
        ))}
      </div>
    </div>
  </section>

  <section class="section" data-home-browser-root>
    <div class="section-head">
      <div>
        <p class="eyebrow">Guides</p>
        <h2 class="section-title">Browse by country</h2>
      </div>
      <p class="small-copy">
        More travel notes at <a href={siteConfig.demFlyersUrl}>DEM Flyers</a>.
      </p>
    </div>

    <HomeGuideMap guides={locationGuideCandidates} />

    <div class="controls-panel country-browser" data-home-browser-controls>
      <div class="controls-grid">
        <div class="control-group">
          <label class="control-label" for="country-search">Search</label>
          <input
            id="country-search"
            name="country-search"
            type="search"
            placeholder="Search quiet coffee, date night, rainy day museums"
            data-home-search-input
          />
        </div>

        <div class="control-group">
          <span class="control-label">Showing</span>
          <p class="browse-count" data-home-results-count>
            {guides.length} guides across {countryCount} countries
          </p>
        </div>

        <div class="control-group location-control-group">
          <span class="control-label">Near me</span>
          <div class="location-control-row">
            <button
              class="location-target-button"
              type="button"
              data-location-target
              aria-label="Show nearby country"
              title="Show nearby country"
            >
              <svg aria-hidden="true" viewBox="0 0 24 24" width="20" height="20">
                <circle cx="12" cy="12" r="6.5" fill="none" stroke="currentColor" stroke-width="2"></circle>
                <circle cx="12" cy="12" r="2" fill="currentColor"></circle>
                <path
                  d="M12 2v3M12 19v3M2 12h3M19 12h3"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-width="2"
                ></path>
              </svg>
            </button>
            <p class="location-status" data-location-status role="status" aria-live="polite"></p>
          </div>
        </div>

        <div class="control-group country-filter-group">
          <span class="control-label">Countries</span>
          <div class="country-filter-list" data-country-filter-list>
            <button
              class="country-filter"
              type="button"
              data-country-filter
              data-country=""
              aria-pressed="true"
            >
              <span>All</span>
              <span class="country-filter-count">{guides.length}</span>
            </button>
            {guidesByCountry.map(({ countryName, countryGuides, countryFlag }) => (
              <button
                class="country-filter"
                type="button"
                data-country-filter
                data-country={countryName.toLowerCase()}
                aria-pressed="false"
              >
                <span>{countryFlag ? `${countryName} ${countryFlag}` : countryName}</span>
                <span class="country-filter-count">{countryGuides.length}</span>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="empty-state" data-home-empty-state>No matching guides. Try a broader search or choose all countries.</div>

    <div
      class="global-search-results"
      data-global-search-results
      role="status"
      aria-live="polite"
      aria-atomic="true"
      aria-hidden="true"
      hidden
    >
      <div class="section-head">
        <div>
          <p class="eyebrow">Search results</p>
          <h3 class="section-title" data-global-search-title>Matching places</h3>
        </div>
      </div>
      <div class="search-results-toolbar" data-global-search-toolbar>
        <p class="small-copy" data-global-search-summary></p>
        <div class="search-view-toggle-group" role="group" aria-label="Search results view">
          <button
            class="search-view-toggle"
            type="button"
            data-search-view-toggle
            data-search-view="grouped"
            aria-pressed="true"
          >
            By country
          </button>
          <button
            class="search-view-toggle"
            type="button"
            data-search-view-toggle
            data-search-view="individual"
            aria-pressed="false"
          >
            Individual
          </button>
        </div>
      </div>
      <div class="search-country-grid" data-grouped-search-list aria-live="polite"></div>
      <div class="search-result-grid" data-global-search-list aria-live="polite" hidden></div>
      <div class="empty-state" data-global-search-empty role="status" aria-live="polite">
        No matching places. Try a broader search.
      </div>
    </div>

    {guidesByCountry.map(({ countryName, countryGuides, countryFlag }) => (
      <div class="country-block" data-country-block data-country={countryName.toLowerCase()}>
        <div class="section-head">
          <div>
            <p class="eyebrow">{countryGuides.length} guide{countryGuides.length === 1 ? "" : "s"}</p>
            <h3 class="section-title">{countryFlag ? `${countryName} ${countryFlag}` : countryName}</h3>
          </div>
        </div>

        <div class="card-grid">
          {countryGuides.map((guide) => (
            <GuideCard guide={guide} />
          ))}
        </div>
      </div>
    ))}
  </section>

  <script is:inline type="module" src="/scripts/home-browser.js"></script>
</Layout>
