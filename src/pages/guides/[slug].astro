---
import Layout from "../../components/Layout.astro";
import { siteConfig } from "../../data/site";
import GuideMap from "../../components/GuideMap.astro";
import PlaceCard from "../../components/PlaceCard.astro";
import { getGuides } from "../../lib/data";
import type { Place } from "../../lib/types";
import {
  getDisplayGuideTags,
  getDisplayPlaceTags,
  getGuideAreaFilters,
  normalizeTagValue,
} from "../../lib/placeTags";
import { renderRichText } from "../../lib/renderRichText";

const DEFAULT_SUGGESTION_PRIORITY = [
  "cozy",
  "date-night",
  "scenic",
  "rainy-day",
  "lively",
  "coffee",
  "breakfast",
  "favorite",
  "fine-dining",
  "fashion",
  "shopping",
  "dessert",
  "cocktails",
  "wine",
  "bakery",
];

const TYPE_SUGGESTION_PRIORITY: Record<string, string[]> = {
  cafe: ["coffee", "breakfast", "quiet", "dessert", "bakery", "pastries"],
  restaurant: ["date-night", "favorite", "fine-dining", "omakase", "ramen", "wine"],
  boutique: ["fashion", "shopping", "design", "vintage", "boutique"],
  bar: ["cocktails", "wine", "nightcap", "lively", "speakeasy"],
  bakery: ["coffee", "breakfast", "pastries", "dessert", "takeaway"],
  "tourist-attraction": ["scenic", "rainy-day", "iconic", "museum", "viewpoint"],
};

function isSuggestibleTag(tag: string, citySlug: string, countrySlug: string): boolean {
  return Boolean(
    tag &&
      tag !== citySlug &&
      tag !== countrySlug &&
      !tag.endsWith("-city") &&
      !tag.endsWith("-county") &&
      !tag.endsWith("-prefecture") &&
      !tag.endsWith("-ward") &&
      !tag.endsWith("-township"),
  );
}

function buildSuggestionList(
  preferredTags: string[],
  fallbackTags: string[],
  limit: number,
  blockedTags: Set<string> = new Set(),
): string[] {
  const suggestions: string[] = [];
  const seen = new Set<string>();
  const availableTags = new Set(fallbackTags);

  for (const tag of [...preferredTags, ...fallbackTags]) {
    if (!tag || blockedTags.has(tag) || seen.has(tag) || !availableTags.has(tag)) {
      continue;
    }

    seen.add(tag);
    suggestions.push(tag);

    if (suggestions.length >= limit) {
      break;
    }
  }

  return suggestions;
}

function getPlaceFilterTags(
  place: Place,
  guideContext: { cityName?: string | null; countryCode?: string | null; countryName?: string | null },
): string[] {
  return [
    ...getDisplayGuideTags(getDisplayPlaceTags(place.tags ?? []), guideContext),
    ...getDisplayPlaceTags(place.vibe_tags ?? []),
  ];
}

export function getStaticPaths() {
  return getGuides().map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;

const placeTagGuideContext = {
  cityName: guide.city_name,
  countryCode: guide.country_code,
  countryName: guide.country_name,
};
const visiblePlaces = guide.places.filter((place) => !place.hidden);
const topPicks = visiblePlaces.filter((place) => guide.featured_place_ids.includes(place.id)).slice(0, 3);
const areaFilters = getGuideAreaFilters(visiblePlaces);
const displayGuideTags = getDisplayGuideTags(guide.list_tags, placeTagGuideContext);
const explicitTypes = [
  ...visiblePlaces.reduce((typeCounts, place) => {
    if (place.primary_category) {
      typeCounts.set(place.primary_category, (typeCounts.get(place.primary_category) ?? 0) + 1);
    }
    return typeCounts;
  }, new Map<string, number>()),
]
  .sort((left, right) => right[1] - left[1] || left[0].localeCompare(right[0]))
  .map(([type]) => type);
const visibleTypeSet = new Set(explicitTypes);
const browseTypes = [...new Set([...guide.top_categories.filter((type) => visibleTypeSet.has(type)), ...explicitTypes])];
const tagCounts = visiblePlaces.reduce((counts, place) => {
  [...new Set(getPlaceFilterTags(place, placeTagGuideContext))].forEach((tag) => {
    const normalizedTag = normalizeTagValue(tag);
    if (normalizedTag) {
      counts.set(normalizedTag, (counts.get(normalizedTag) ?? 0) + 1);
    }
  });
  return counts;
}, new Map<string, number>());
const allTags = [...tagCounts.keys()].sort((left, right) => left.localeCompare(right));
const citySlug = normalizeTagValue(guide.city_name);
const countrySlug = normalizeTagValue(guide.country_name);
const tagFallbacks = [...tagCounts.entries()]
  .map(([tag, count]) => ({ tag, count }))
  .filter(({ tag }) => isSuggestibleTag(tag, citySlug, countrySlug))
  .sort((left, right) => right.count - left.count || left.tag.localeCompare(right.tag))
  .map(({ tag }) => tag);
const defaultSuggestions = buildSuggestionList(DEFAULT_SUGGESTION_PRIORITY, tagFallbacks, 6);
const typeSeedTags = Object.fromEntries(
  browseTypes.map((type) => {
    const typeKey = normalizeTagValue(type);
    return [
      typeKey,
      [...new Set([typeKey, ...((TYPE_SUGGESTION_PRIORITY[typeKey] ?? []).map((tag) => normalizeTagValue(tag)))])],
    ];
  }),
);
const guideDescriptionHtml = renderRichText(guide.description);
---

<Layout title={`${guide.title} · ${siteConfig.siteName}`} description={guide.description ?? undefined}>
  <section class="hero">
    <div class="hero-grid">
      <div class="section-stack">
        <a class="utility-link small-copy" href="/">← Back to all guides</a>
        <p class="eyebrow">{guide.country_name}</p>
        <h1>{guide.title}</h1>
        {
          guideDescriptionHtml ? (
            <p class="lede rich-copy" set:html={guideDescriptionHtml} />
          ) : (
            <p class="lede">{siteConfig.guide.fallbackDescription}</p>
          )
        }
        <div class="hero-meta">
          <span class="stat-pill">{guide.place_count} places</span>
          {guide.source_url && (
            <a class="action-pill" href={guide.source_url} target="_blank" rel="noreferrer">
              View source list
            </a>
          )}
        </div>
      </div>

      {displayGuideTags.length > 0 && (
        <div class="section-stack">
          <p class="eyebrow">List tags</p>
          <div class="tag-row">
            {displayGuideTags.map((tag) => (
              <span class="tag-pill">#{tag}</span>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  {topPicks.length > 0 && (
    <section class="section">
      <div class="section-head">
        <div>
          <p class="eyebrow">Start here</p>
          <h2 class="section-title">Top picks</h2>
        </div>
      </div>

      <div class="top-picks-grid">
        {topPicks.map((place) => (
          <PlaceCard place={place} guideContext={placeTagGuideContext} />
        ))}
      </div>
    </section>
  )}

  <section
    class="section browse-section"
    data-guide-root
    data-guide-slug={guide.slug}
    data-all-tags={JSON.stringify(allTags)}
    data-default-suggestions={JSON.stringify(defaultSuggestions)}
    data-type-seeds={JSON.stringify(typeSeedTags)}
  >
    <div class="section-head">
      <div>
        <p class="eyebrow">Browse</p>
        <h2 class="section-title">Places</h2>
      </div>
    </div>

    <div class="browse-layout" data-browse-layout>
      <div class="browse-main">
        <div class="controls-panel">
          <div class="controls-grid" data-guide-controls>
            <div class="control-group control-group-search" style="grid-column: 1 / -1;">
              <div class="control-head">
                <label class="control-label" for="guide-search">Search</label>
                <span class="small-copy search-hint">Type `#` to add a tag filter.</span>
              </div>
              <div class="search-shell">
                <input
                  id="guide-search"
                  name="guide-search"
                  type="search"
                  placeholder="Search places, notes, neighborhoods, or type #tag"
                  data-search-input
                  autocomplete="off"
                  autocapitalize="off"
                  spellcheck="false"
                />
                <div class="tag-autocomplete" data-tag-autocomplete hidden></div>
              </div>
              <div class="selected-tag-row" data-selected-tags hidden></div>
            </div>

            <div class="control-group">
              <label class="control-label" for="guide-sort">Sort</label>
              <select id="guide-sort" name="guide-sort" data-sort-select>
                <option value="curated">Curated order</option>
                <option value="name">Name</option>
                <option value="neighborhood">Neighborhood</option>
              </select>
            </div>

            {areaFilters.length > 0 && (
              <div class="control-group" style="grid-column: 1 / -1;">
                <span class="control-label">Area</span>
                <div class="tag-row">
                  <button class="tag-pill" type="button" data-area-filter data-area="" data-area-label="All areas">
                    All
                  </button>
                  {areaFilters.map((area) => (
                    <button
                      class="tag-pill"
                      type="button"
                      data-area-filter
                      data-area={area.value}
                      data-area-label={area.label}
                    >
                      {area.label} ({area.count})
                    </button>
                  ))}
                </div>
              </div>
            )}

            {browseTypes.length > 0 && (
              <div class="control-group" style="grid-column: 1 / -1;">
                <span class="control-label">Type</span>
                <div class="tag-row">
                  <button class="tag-pill" type="button" data-type-filter data-type="">
                    All
                  </button>
                  {browseTypes.map((type) => (
                    <button class="tag-pill" type="button" data-type-filter data-type={normalizeTagValue(type)}>
                      {type}
                    </button>
                  ))}
                </div>
              </div>
            )}

            {defaultSuggestions.length > 0 && (
              <div class="control-group" style="grid-column: 1 / -1;">
                <div class="control-head">
                  <span class="control-label">Popular tags</span>
                  <span class="small-copy search-hint">Click to add, or type `#` to browse all tags.</span>
                </div>
                <div class="tag-row" data-suggestion-list>
                  {defaultSuggestions.map((tag) => (
                    <button class="tag-pill" type="button" data-suggestion-tag={tag}>
                      #{tag}
                      <span class="visually-hidden" data-tag-count-text></span>
                    </button>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>

        <div class="results-row">
          <p class="small-copy" data-results-count>{visiblePlaces.length} places</p>
          <button class="map-filter-reset" type="button" data-map-filter-reset hidden>Reset map</button>
        </div>
        <p class="map-filter-status small-copy" data-area-filter-status hidden></p>
        <p class="map-filter-status small-copy" data-map-filter-status hidden>Filtered to the visible map area.</p>
        <div class="empty-state" data-empty-state>No matches. Try a broader search or clear the tag filter.</div>

        <div class="card-grid" data-kind="places" data-place-list>
          {visiblePlaces.map((place) => (
            <PlaceCard place={place} guideContext={placeTagGuideContext} />
          ))}
        </div>
      </div>

      <GuideMap places={visiblePlaces} />
    </div>
  </section>

  <script is:inline type="module" src="/scripts/guide-filters.js"></script>
</Layout>
