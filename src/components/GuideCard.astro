---
import type { GuideManifest } from "../lib/types";

interface Props {
  guide: GuideManifest;
}

const { guide } = Astro.props;
---

<a class="guide-card" href={`/guides/${guide.slug}/`}>
  <div class="section-stack">
    <p class="eyebrow">{guide.country_name}</p>
    <h3>{guide.title}</h3>
    <p>{guide.description ?? "A personal guide with fast map handoff and curated picks."}</p>
  </div>

  <div class="tag-row">
    {guide.list_tags.slice(0, 4).map((tag) => (
      <span class="tag-pill">#{tag}</span>
    ))}
  </div>

  <div class="guide-card-footer">
    <div class="stats-row">
      <span class="stat-pill">{guide.place_count} places</span>
      {guide.top_categories[0] && <span class="stat-pill">{guide.top_categories[0]}</span>}
    </div>

    {guide.featured_names.length > 0 && (
      <p class="small-copy">{guide.featured_names.join(" · ")}</p>
    )}
  </div>
</a>
