---
import type { GuideManifest } from "../lib/types";
import { renderRichText } from "../lib/renderRichText";

interface Props {
  guide: GuideManifest;
}

const { guide } = Astro.props;
const guideDescriptionHtml = renderRichText(guide.description);
---

<article class="guide-card">
  <a class="guide-card-link" href={`/guides/${guide.slug}/`} aria-label={`Open ${guide.title}`}></a>

  <div class="section-stack">
    <p class="eyebrow">{guide.country_name}</p>
    <h3>{guide.title}</h3>
    {
      guideDescriptionHtml ? (
        <p class="rich-copy" set:html={guideDescriptionHtml} />
      ) : (
        <p>Saved places from Michael's travel notes.</p>
      )
    }
  </div>

  <div class="tag-row">
    {guide.list_tags.slice(0, 4).map((tag) => (
      <span class="tag-pill">#{tag}</span>
    ))}
  </div>

  <div class="guide-card-footer">
    <div class="stats-row">
      <span class="stat-pill">{guide.place_count} places</span>
      {guide.top_categories[0] && <span class="stat-pill">{guide.top_categories[0]}</span>}
    </div>

  </div>
</article>
