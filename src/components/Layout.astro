---

import "../styles/global.css";
import "favorite-places:site-theme";
import { siteConfig } from "../data/site";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const metaDescription = description ?? siteConfig.siteDescription;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <meta name="author" content={siteConfig.ownerName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    {siteConfig.defaultSeoImage && <meta property="og:image" content={siteConfig.defaultSeoImage} />}
    {siteConfig.favicon && (
      <link
        rel="icon"
        href={siteConfig.favicon.href}
        type={siteConfig.favicon.type}
        sizes={siteConfig.favicon.sizes}
      />
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&family=Raleway:wght@600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="ui-site-header">
      {
        siteConfig.logo ? (
          <a class="ui-site-title" href={siteConfig.logo.href} aria-label={siteConfig.logo.alt}>
            <img src={siteConfig.logo.src} alt={siteConfig.logo.alt} />
          </a>
        ) : (
          <a class="ui-site-title ui-site-title-text" href="/" aria-label={siteConfig.siteName}>
            {siteConfig.siteName}
          </a>
        )
      }
      <nav class="ui-site-nav" aria-label="Primary">
        {siteConfig.navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
      </nav>
    </header>
    <main class="ui-page-shell">
      <slot />
    </main>
  </body>
</html>
